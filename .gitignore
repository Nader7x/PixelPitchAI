# Standard .NET .gitignore
# Build results
[Bb]in/
[Oo]bj/
# Visual Studio temporary files, build results
/[Bb]in/
/[Oo]bj/


# Rider and VS Code
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
.vscode/

# OS generated files
.DS_Store
Thumbs.db

# NuGet
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
!**/packages/build/
!**/packages/repositories.config


# Visual Studio
*.vspscc
*.vssscc
*.dbmdl
*.bak
*.backup
*.log
*.vs/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Others
*.swp
*.tmp
*.tmp_proj
*.pidb
*.svclog
*.scc

# User-specific files
*.userprefs

# Custom project ignores
/workspace.xml
# Rider ignored files
/projectSettingsUpdater.xml
/modules.xml
/.idea.Footex.iml
/contentModel.xml
/vcs.xml
/.idea/
# Editor-based HTTP Client requests
/httpRequests/
# Datasource local storage ignored files
/dataSources/
/dataSources.local.xml
/Footex/Logs

# Environment variables
.env
.env.*
/scripts/
Infrastructure/Migrations
certs