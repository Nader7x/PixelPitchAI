{
  "name": "football_match_simulation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "docker:dev": "docker-compose up --build",
    "docker:dev:bg": "docker-compose up --build -d",
    "docker:dev:down": "docker-compose down",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up --build",
    "docker:prod:bg": "docker-compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:prod:ssl": "docker-compose -f docker-compose.prod.yml --profile ssl-init up --build -d",
    "docker:prod:monitoring": "docker-compose -f docker-compose.prod.yml --profile monitoring --profile with-redis up --build -d",
    "docker:build:dev": "docker build --target development -t football-simulation:dev .",
    "docker:build:prod": "docker build --target production -t football-simulation:prod .",
    "docker:logs:dev": "docker-compose logs -f",
    "docker:logs:prod": "docker-compose -f docker-compose.prod.yml logs -f",
    "docker:clean": "docker system prune -f && docker volume prune -f",
    "ssl:setup": "powershell -ExecutionPolicy Bypass -File setup-ssl.ps1",
    "ssl:letsencrypt": "powershell -ExecutionPolicy Bypass -File setup-ssl.ps1 -LetsEncrypt",
    "ssl:selfsigned": "powershell -ExecutionPolicy Bypass -File setup-ssl.ps1 -SelfSigned -Domain localhost",
    "validate:docker": "powershell -ExecutionPolicy Bypass -File validate-docker.ps1",
    "security:scan": "docker scout cves football-simulation:prod || echo 'Docker Scout not available'",
    "health:check": "curl -f http://localhost:3000/api/health || echo 'Health check failed'",
    "deploy:prod": "powershell -ExecutionPolicy Bypass -File deploy-production.ps1",
    "deploy:staging": "powershell -ExecutionPolicy Bypass -File deploy-production.ps1 -Domain staging.yourdomain.com",
    "backup:create": "docker run --rm -v football_app_logs:/data -v ${PWD}/backups:/backup alpine tar czf /backup/backup-$(date +%Y%m%d).tar.gz /data",
    "logs:follow": "docker-compose -f docker-compose.prod.yml logs -f --tail=100",
    "status": "docker ps --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}'",
    "update:deps": "pnpm update --latest"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@microsoft/signalr": "^8.0.17",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/three": "^0.176.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "gantt-task-react": "^0.3.9",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.509.0",
    "next": "^16.2.6",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "node-fetch": "^3.3.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-phone-input-2": "^2.15.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.176.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "daisyui": "^5.5.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
