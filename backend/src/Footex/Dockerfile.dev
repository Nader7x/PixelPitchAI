# Development Dockerfile with hot reload support
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS development
WORKDIR /app

# Install required tools and dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install dotnet tools globally
RUN dotnet tool install --global dotnet-ef --version 9.* && \
    dotnet tool install --global dotnet-watch
ENV PATH="${PATH}:/root/.dotnet/tools"
ENV ASPNETCORE_Kestrel__Certificates__Default__Password="00000000" \
    ASPNETCORE_Kestrel__Certificates__Default__Path="/app/aspnetapp.pfx"

# Copy project files for dependency restoration
COPY ["src/Footex/Footex.csproj", "src/Footex/"]
COPY ["src/Application/Application.csproj", "src/Application/"]
COPY ["src/Domain/Domain.csproj", "src/Domain/"]
COPY ["src/Infrastructure/Infrastructure.csproj", "src/Infrastructure/"]

# Restore dependencies
RUN dotnet restore "src/Footex/Footex.csproj"

# Copy entire source code
COPY . .

# Create required directories
RUN mkdir -p /app/Logs /app/temp /app/wwwroot && \
    chmod 755 /app/Logs /app/temp /app/wwwroot

# Set working directory to the main project
WORKDIR /app/src/Footex

# Expose ports for HTTP and HTTPS
EXPOSE 8080
EXPOSE 8081

# Create a startup script for development
RUN echo '#!/bin/bash\n\
echo "Starting Footex Development Server..."\n\
\n\
CERT_PATH="/app/aspnetapp.pfx"\n\
# Use the password from the environment variable set in docker-compose.yml\n\
CERT_PASSWORD="$ASPNETCORE_Kestrel__Certificates__Default__Password"\n\
\n\
# Create certs directory if it does not exist\n\
mkdir -p /app/certs\n\
\n\
# Always generate a fresh certificate for development\n\
echo "Generating new self-signed certificate for development..."\n\
# Clean any existing certificates\n\
dotnet dev-certs https --clean\n\
# Generate new certificate with trust\n\
dotnet dev-certs https -ep "$CERT_PATH" -p "$CERT_PASSWORD" --trust\n\
# Also export to the mounted certs volume for host access\n\
dotnet dev-certs https -ep "/app/certs/aspnetapp.pfx" -p "$CERT_PASSWORD"\n\
# Export the certificate without password for browser import\n\
dotnet dev-certs https -ep "/app/certs/aspnetapp.crt" --format PEM\n\
echo "Certificate generated and stored at $CERT_PATH."\n\
echo "Certificate also exported to /app/certs/ for host access."\n\
echo "PEM certificate exported to /app/certs/aspnetapp.crt for browser import."\n\
\n\
echo "Restoring packages..."\n\
dotnet restore\n\
echo "Adding new migration..."\n\
# Generate a unique migration name to avoid conflicts on restart\n\
MIGRATION_NAME="DevMigration_$(date +%Y%m%d%H%M%S)"\n\
# Use correct relative paths from the /app/Footex working directory and a valid context name\n\
dotnet ef migrations add "$MIGRATION_NAME" --project ../Infrastructure/Infrastructure.csproj --startup-project Footex.csproj --context Infrastructure.FootballDbContext --output-dir ../Infrastructure/Migrations\n\
echo "Building project..."\n\
dotnet build --no-restore\n\
echo "Starting with hot reload..."\n\
exec dotnet watch run --urls "http://0.0.0.0:8080;https://0.0.0.0:8081" --no-restore' > /app/start-dev.sh && \
    chmod +x /app/start-dev.sh

# Health check for development
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:8080/api/health || exit 1
  
# Add these lines towards the end of your Dockerfile.dev
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser
USER appuser

# Entry point for development with watch and automatic restart
ENTRYPOINT ["/app/start-dev.sh"]
