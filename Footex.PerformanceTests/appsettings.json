{
  "PerformanceTests": {
    "BaseUrl": "https://localhost:7082",
    "Duration": {
      "ShortTestMinutes": 1,
      "MediumTestMinutes": 2,
      "LongTestMinutes": 5,
      "StressTestMinutes": 10
    },
    "Load": {
      "LightLoadRps": 5,
      "MediumLoadRps": 15,
      "HeavyLoadRps": 50,
      "StressLoadRps": 100,
      "ConcurrentUsers": 10,
      "MaxConcurrentUsers": 50
    },
    "Cache": {
      "WarmupRequests": 10,
      "CacheHitTestMinutes": 2,
      "ExpectedCacheHitRatio": 0.8
    },
    "Search": {
      "CommonQueries": [
        "manchester",
        "liverpool",
        "barcelona",
        "madrid",
        "juventus",
        "messi",
        "ronaldo",
        "neymar",
        "mbappe",
        "haaland",
        "brazil",
        "argentina",
        "spain",
        "germany",
        "france"
      ],
      "ResultLimits": [
        5,
        10,
        20,
        50
      ],
      "FuzzySearchPercentage": 0.3
    },
    "Benchmark": {
      "WarmupCount": 3,
      "IterationCount": 10,
      "EnableMemoryDiagnoser": true,
      "EnableDetailedTiming": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "NBomber": "Information"
    }
  }
}
